# ============================================================
# 币安 U 本位合约模拟交易程序 - 配置模板
# ------------------------------------------------------------
# 使用方法：
# 1. 复制本文件并重命名为 .env
# 2. 按需修改里面的配置值
# 3. 程序启动时会自动读取 .env
# 4. .env 包含敏感信息，不要提交到 GitHub
#
# Linux / macOS:
#   cp .env.example .env
# Windows PowerShell:
#   Copy-Item .env.example .env
# ============================================================


# ============================================================
# 一、基础交易配置
# ------------------------------------------------------------
# 这部分决定“交易什么”“按什么周期交易”“每次用多大仓位模拟”
# ============================================================

# 交易对
# 必须填写 Binance U 本位合约支持的交易对，建议全部大写。
# 常见示例：
#   BTCUSDT
#   ETHUSDT
#   SOLUSDT
#   DOGEUSDT
SYMBOL=BTCUSDT

# 交易周期
# 表示程序按哪个 K 线周期执行一轮“判断方向 -> 开仓 -> 平仓/换仓”。
# 可用示例：
#   1m   = 1分钟
#   3m   = 3分钟
#   5m   = 5分钟
#   15m  = 15分钟
# 周期越短，交易频率越高，噪音通常也越大。
INTERVAL=5m

# 每次交易使用的名义金额（单位：USDT）
# 这不是账户余额，而是每笔模拟交易按多少 USDT 计算仓位。
# 例如：
#   NOTIONAL_USDT=100
# 如果当前价格是 50000，那么大致仓位数量约为 100 / 50000 = 0.002
NOTIONAL_USDT=100

# 手续费率（taker 吃单费率）
# 常见默认值为 0.0004，即 0.04%。
# 因为当前程序是模拟交易，所以这里需要手动填写费率。
TAKER_FEE_RATE=0.0004

# 杠杆倍数
# 当前程序里主要用于风险表达和结果理解，不直接改变行情本身。
# 示例：
#   5  = 5倍杠杆
#   10 = 10倍杠杆
LEVERAGE=5


# ============================================================
# 二、交易时间窗口
# ------------------------------------------------------------
# 用于限制程序只在某个时间段内允许开新仓。
# 时间使用“本机本地时间”。
# ============================================================

# 允许开始交易的时间
# 格式必须是：HH:MM
# 示例：
#   00:00
#   09:30
#   13:00
TRADE_START_TIME=00:00

# 允许结束交易的时间
# 到了这个时间后，程序将不再开新仓。
# 如果你希望全天运行，可以使用：
#   TRADE_START_TIME=00:00
#   TRADE_END_TIME=23:59
TRADE_END_TIME=23:59

# 持仓状态输出频率（秒）
# 程序运行时会定时输出当前持仓、盈亏、剩余时间等信息。
# 示例：
#   60 = 每分钟输出一次
#   30 = 每30秒输出一次
STATUS_INTERVAL_SECONDS=60


# ============================================================
# 三、技术指标参数
# ------------------------------------------------------------
# 这部分控制程序如何判断当前周期更适合做多还是做空。
# 一般不建议一次改很多项，最好单项微调后观察结果。
# ============================================================

# EMA 快线周期
# 数值越小，对短期价格变化越敏感。
# 常见范围：10 ~ 30
EMA_FAST=20

# EMA 慢线周期
# 用于观察相对更平滑的趋势方向。
# 常见范围：40 ~ 100
EMA_SLOW=50

# ADX 周期
# 用于衡量趋势强度。
# 常见默认值：14
ADX_PERIOD=14

# 成交量均线周期
# 用于判断当前成交量相对近期是否放大。
VOLUME_MA_PERIOD=20

# K线结构观察根数
# 用于观察最近多少根已收盘 K 线的高低点结构。
# 数值越大，结构判断越平滑，但也越慢。
STRUCTURE_LOOKBACK=3


# ============================================================
# 四、止盈止损配置
# ------------------------------------------------------------
# 如果开启，程序可能在一个周期尚未结束前就提前平仓。
# ============================================================

# 是否启用止盈
# true  = 开启
# false = 关闭
ENABLE_TAKE_PROFIT=false

# 止盈比例
# 例如：
#   0.0045 = 0.45%
#   0.01   = 1%
# 如果做多，价格上涨到目标比例则止盈；
# 如果做空，价格下跌到目标比例则止盈。
TAKE_PROFIT_PCT=0.0045

# 是否启用止损
# true  = 开启
# false = 关闭
ENABLE_STOP_LOSS=false

# 止损比例
# 例如：
#   0.0035 = 0.35%
#   0.005  = 0.5%
# 如果做多，价格下跌到目标比例则止损；
# 如果做空，价格上涨到目标比例则止损。
STOP_LOSS_PCT=0.0035

# 周期边界触发窗口（秒）
# 程序会在“新周期开始后的这几秒内”允许触发本周期交易逻辑。
# 适当保留几秒缓冲，可减少因网络波动或调度延迟而错过开仓。
CYCLE_TRIGGER_WINDOW_SECONDS=5

# 开仓失败后重试间隔（秒）
# 如果某周期本应开仓但临时失败，程序会按这个间隔自动重试补开。
OPEN_RETRY_INTERVAL_SECONDS=5

# 最大持仓时间（秒）
# 可选项。
# 如果不填写，程序通常会按当前周期长度自动计算最大持仓时间。
# 例如：
#   INTERVAL=5m  -> 默认约 300 秒
# 如需手动覆盖可取消注释：
# MAX_HOLD_SECONDS=300


# ============================================================
# 五、代理配置
# ------------------------------------------------------------
# 如果当前网络环境访问 Binance 需要代理，就在这里配置。
# ============================================================

# 是否启用代理
# true  = 使用代理
# false = 不使用代理
USE_PROXY=false

# 代理地址
# 常见示例：
#   http://127.0.0.1:7890
#   http://127.0.0.1:7898
# 如果不使用代理，保持为空即可。
PROXY_URL=


# ============================================================
# 六、AI 参数优化器配置
# ------------------------------------------------------------
# 这部分用于让程序根据历史交易结果，调用 AI 给出参数优化建议。
# 如果你暂时不用这个功能，可以直接保持 AI_ENABLED=false。
# ============================================================

# 是否启用 AI 优化功能
# true  = 启用
# false = 禁用
AI_ENABLED=false

# AI 接口基础地址
# 填写你实际使用的兼容接口地址。
# 常见格式示例：
#   https://api.openai.com/v1
AI_BASE_URL=https://api.openai.com/v1

# AI API Key
# 这里填写你自己的密钥。
# 注意：.env 不要上传到公开仓库。
AI_API_KEY=your-api-key-here

# AI 模型名称
# 填写你实际要调用的模型名。
# 示例：
#   gpt-4
#   gpt-4o
#   claude-opus-4-6
AI_MODEL=gpt-4

# AI 请求超时时间（秒）
# 如果接口响应较慢，可以适当增大。
AI_TIMEOUT_SECONDS=60

# 是否启用自动优化
# true  = 达到触发条件后自动发起优化建议
# false = 仅手动触发
AI_AUTO_OPTIMIZE_ENABLED=false

# 自动触发优化的最低胜率阈值（百分比）
# 当胜率低于这个值，且交易次数达到要求时，可触发优化逻辑。
# 例如：40 表示低于 40% 时才考虑触发。
AI_AUTO_TRIGGER_MIN_WIN_RATE=40

# 自动触发优化的最少交易次数
# 样本太少时不建议优化，因此通常会设置一个最少交易笔数。
AI_AUTO_TRIGGER_MIN_TRADES=20

# 手动触发 AI 优化时是否要求确认
# true  = 需要确认
# false = 直接执行
AI_REQUIRE_CONFIRM_ON_MANUAL=true

# 自动触发 AI 优化时是否要求确认
# true  = 自动触发前先确认
# false = 直接执行
AI_REQUIRE_CONFIRM_ON_AUTO=true

# AI 最多返回多少条建议
AI_MAX_SUGGESTION_COUNT=5

# 允许 AI 修改的参数列表
# 多个参数之间用英文逗号分隔。
# 建议只开放“技术参数”和“风控参数”，避免 AI 修改基础运行配置。
AI_ALLOWED_PARAMS=EMA_FAST,EMA_SLOW,ADX_PERIOD,VOLUME_MA_PERIOD,STRUCTURE_LOOKBACK,ENABLE_TAKE_PROFIT,TAKE_PROFIT_PCT,ENABLE_STOP_LOSS,STOP_LOSS_PCT,MAX_HOLD_SECONDS

# 禁止 AI 修改的参数列表
# 一般包括交易对、周期、仓位、API 信息、代理信息等关键配置。
AI_BLOCKED_PARAMS=SYMBOL,INTERVAL,NOTIONAL_USDT,TAKER_FEE_RATE,LEVERAGE,TRADE_START_TIME,TRADE_END_TIME,USE_PROXY,PROXY_URL,AI_BASE_URL,AI_API_KEY,AI_MODEL


# ============================================================
# 七、Dashboard 配置
# ------------------------------------------------------------
# Dashboard 是项目的 Web 管理界面。
# ============================================================

# Dashboard 监听地址
# 常见设置：
#   127.0.0.1 = 只允许本机访问
#   0.0.0.0   = 允许局域网/服务器外部访问
DASHBOARD_HOST=0.0.0.0

# Dashboard 监听端口
# 访问地址示例：
#   http://127.0.0.1:8080
DASHBOARD_PORT=8080

# Dashboard 启动时是否自动启动策略
# true  = 打开面板时自动开始策略
# false = 仅启动 Dashboard，不自动开始策略
DASHBOARD_AUTO_START_STRATEGY=false


# ============================================================
# 八、运行时目录配置
# ------------------------------------------------------------
# 程序运行过程中生成的日志、快照、CSV、状态文件都会放到这里。
# ============================================================

# 运行时输出目录
# 可以写相对路径，也可以写绝对路径。
# 默认使用项目根目录下的 runtime 文件夹。
RUNTIME_DIR=runtime

